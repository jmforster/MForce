{
  "sampleRate": 48000,
  "seconds": 3,
  "graph": {
    "nodes": [
      {
        "id": "env",
        "type": "Envelope",
        "params": { "preset": "adsr", "attack": 0.08, "decay": 0.1, "sustainLevel": 0.65, "release": 0.0 }
      },
      {
        "id": "sq",
        "type": "PulseSource",
        "params": { "frequency": 260.0, "amplitude": { "ref": "env" }, "dutyCycle": 0.5, "bend": 0.0 }
      },
      {
        "id": "ch1",
        "type": "SoundChannel",
        "inputs": { "source": "sq" },
        "params": { "volume": 0.8, "pan": 0.0 }
      },
      {
        "id": "mix",
        "type": "StereoMixer",
        "inputs": { "channels": ["ch1"] },
        "params": { "gainL": 1.0, "gainR": 1.0 }
      }
    ],
    "output": "mix"
  }
}
