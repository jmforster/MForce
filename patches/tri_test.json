{
  "sampleRate": 48000,
  "seconds": 3,
  "graph": {
    "nodes": [
      {
        "id": "env",
        "type": "Envelope",
        "params": { "preset": "adsr", "attack": 0.1, "decay": 0.15, "sustainLevel": 0.6, "release": 0.0 }
      },
      {
        "id": "tri",
        "type": "TriangleSource",
        "params": { "frequency": 330.0, "amplitude": { "ref": "env" }, "bias": 0.5 }
      },
      {
        "id": "ch1",
        "type": "SoundChannel",
        "inputs": { "source": "tri" },
        "params": { "volume": 0.8, "pan": 0.0 }
      },
      {
        "id": "mix",
        "type": "StereoMixer",
        "inputs": { "channels": ["ch1"] },
        "params": { "gainL": 1.0, "gainR": 1.0 }
      }
    ],
    "output": "mix"
  }
}
