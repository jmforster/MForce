{
  "sampleRate": 48000, "seconds": 3,
  "graph": { "nodes": [
    { "id": "ampEnv", "type": "Envelope", "params": { "preset": "adsr", "attack": 0.08, "decay": 0.1, "sustainLevel": 0.6, "release": 0.0 } },
    { "id": "band", "type": "BandSpectrum", "params": {
        "startFreq": 100, "freqIncrement": 50,
