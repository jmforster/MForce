{
  "sampleRate": 48000, "seconds": 4,
  "graph": { "nodes": [
    { "id": "roEnv", "type": "Envelope", "params": { "preset": "adsr", "attack": 0.05, "decay": 0.2, "sustainLevel": 0.3, "release": 0.0 } },
    { "id": "ampEnv", "type": "Envelope", "params": { "preset": "ar", "attack": 0.02 } },
    { "id": "as2", "type": "AdditiveSource2", "params": {
        "frequency": 220.0, "amplitude": { "ref": "ampEnv" },
        "partialMode": "default", "partialCount": 40,
        "amplEnvelopes": [
          { "envelope": { "ref": "roEnv" }, "filter": "all", "from": 1, "to": 40 }
        ]
    }},
    { "id": "ch1", "type": "SoundChannel", "inputs": { "source": "as2" }, "params": { "volume": 0.8, "pan": 0.0 } },
    { "id": "mix", "type": "StereoMixer", "inputs": { "channels": ["ch1"] }, "params": { "gainL": 1.0, "gainR": 1.0 } }
  ], "output": "mix" }
}
